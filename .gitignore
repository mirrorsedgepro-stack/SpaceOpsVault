# Obsidian workspace state — user-specific, do not share
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Plugin user data (SRS progress, plugin settings) — user-specific
.obsidian/plugins/*/data.json

# Shared plugin configs — track these so clones get the correct setup
!.obsidian/plugins/templater-obsidian/data.json
!.obsidian/plugins/calendar/data.json

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Zip exports
*.zip

# gemini-cli settings
.gemini/

# GitHub App credentials
gha-creds-*.json
